PORT=5000
DB_SSL=true
JWT_SECRET=replace_with_a_long_random_secret

# Use either DATABASE_URL or the PG* variables below.
# For many local networks, the Supabase pooler URL is more reliable than the direct host.
# Example:
# DATABASE_URL=postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

PGHOST=
PGPORT=5432
PGUSER=postgres
PGPASSWORD=
PGDATABASE=postgres
